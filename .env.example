# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string
# Get one at https://console.neon.tech (free tier OK for dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Public app URL (used for redirects, links, QR URLs)
APP_URL="http://localhost:3000"

# Stripe Billing (Phase 2)
# Récup STRIPE_SECRET_KEY depuis https://dashboard.stripe.com/test/apikeys
# Crée 3 produits dans Stripe Dashboard puis colle les price_id ici :
#   - Recurring 49 €/mois → STRIPE_PRICE_MONTHLY
#   - Recurring 499 €/an → STRIPE_PRICE_ANNUAL
#   - One-time 2000 € → STRIPE_PRICE_LIFETIME
# STRIPE_WEBHOOK_SECRET vient de `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_ANNUAL=""
STRIPE_PRICE_LIFETIME=""

# Vercel Blob storage (Phase 3) — recommandé
# Storage des images : logos, covers de menu, photos de plats.
# Comment activer en prod : Vercel dashboard → ton projet → Storage → Blob → Create.
# Le token BLOB_READ_WRITE_TOKEN est auto-injecté par Vercel.
# En local : `vercel env pull .env.local` pour récupérer le token.
BLOB_READ_WRITE_TOKEN=""

# Cloudflare R2 storage (legacy, optionnel)
# Plus utilisé par défaut depuis le passage à Vercel Blob, mais les variables
# restent acceptées si tu veux les utiliser ailleurs.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# Pusher (Phase 7 — temps réel cuisine)
# Crée une app sur https://dashboard.pusher.com (Channels, free tier 200k msg/jour)
# Si vide, le client public continuera à polling toutes les 5s — fonctionnel mais moins instantané.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# Resend email transactionnel (Phase 10)
# https://resend.com — free tier 3000 emails/mois, 100/jour.
# Le domain doit être vérifié pour envoyer (ou utiliser onboarding@resend.dev en test).
RESEND_API_KEY=""
EMAIL_FROM="QR Restaurant <noreply@qr-resto.fr>"
