# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string
# Get one at https://console.neon.tech (free tier OK for dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Public app URL (used for redirects, links, QR URLs)
APP_URL="http://localhost:3000"

# --- Phase 2+ : décommenter quand on attaque ---

