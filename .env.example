# Copy to .env.local and fill in. Never commit .env.local.

# Neon Postgres connection string
# Get one at https://console.neon.tech (free tier OK for dev)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Public app URL (used for redirects, links, QR URLs)
APP_URL="http://localhost:3000"

# Stripe Billing (Phase 2)
# Récup STRIPE_SECRET_KEY depuis https://dashboard.stripe.com/test/apikeys
# Crée 3 produits dans Stripe Dashboard puis colle les price_id ici :
#   - Recurring 49 €/mois → STRIPE_PRICE_MONTHLY
#   - Recurring 499 €/an → STRIPE_PRICE_ANNUAL
#   - One-time 2000 € → STRIPE_PRICE_LIFETIME
# STRIPE_WEBHOOK_SECRET vient de `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_ANNUAL=""
STRIPE_PRICE_LIFETIME=""

# Cloudflare R2 storage (Phase 3)
# Crée un bucket R2 sur https://dash.cloudflare.com → R2 → Create bucket
# Active "Public access" puis colle le public URL (https://pub-xxx.r2.dev)
# Token API : R2 → Manage R2 API tokens → Create API token (read+write sur le bucket)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# --- Phases ultérieures ---

